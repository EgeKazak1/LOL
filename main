--[[
    BROOKHAVEN EASTER 2026 - UNIVERSAL GOD MODE (v3.1 FINAL - INSTANT TP & ANTI-AFK)
    [+] CİHAZ: PC (Windows), Mobile (Android/iOS)
    [+] EXECUTOR: Xeno, Wave, Solara, Hydrogen, Fluxus, Delta, Vega X vb.
    [+] ÖZELLİK: Full Radar (NATIVE HOOK), ESP, VIP Bypass, Instant Farm, Anti-AFK
]]

if not game:IsLoaded() then game.Loaded:Wait() end

if _G.EasterGodModeExecuted then 
    warn("[SİSTEM]: Script zaten çalışıyor!") 
    return 
end
_G.EasterGodModeExecuted = true

local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")
local VU = game:GetService("VirtualUser")
local LP = Players.LocalPlayer

-- [ANTI-AFK SİSTEMİ]: 20 Dakika kicklenmesini engeller
LP.Idled:Connect(function()
    VU:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VU:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    print("[ANTI-AFK]: Kick engellendi!")
end)

-- Modül Yakalayıcı
local Remotes, EggController, EggHunts, UnlockableController, GamepassController
pcall(function()
    Remotes = require(RS:WaitForChild("Packages"):WaitForChild("Remotes"))
    EggController = require(RS:WaitForChild("Modules"):WaitForChild("Client"):WaitForChild("LiveOps"):WaitForChild("EggHuntController"))
    EggHunts = require(RS:WaitForChild("Modules"):WaitForChild("Shared"):WaitForChild("LiveOps"):WaitForChild("EggHunts"))
    UnlockableController = require(RS:WaitForChild("Modules"):WaitForChild("Client"):WaitForChild("PlayerData"):WaitForChild("UnlockableController"))
    GamepassController = require(RS:WaitForChild("Modules"):WaitForChild("Client"):WaitForChild("UI"):WaitForChild("Gamepass"):WaitForChild("GamepassController"))
end)

-- Global Ayarlar
local Config = {
    Farm = false,
    ESP = false,
    SpeedActive = false,
    Difficulty = "Easy",
    WalkSpeed = 60
}

local Difficulties = {"Easy", "Medium", "Hard", "Eggstreme"}
local DiffIndex = 1

-- [ULTIMATE BYPASS]: NATIVE HOOK
local function GlobalBypass()
    pcall(function()
        if UnlockableController and type(UnlockableController.IsFeatureUnlocked) == "function" then
            local oldFeature = UnlockableController.IsFeatureUnlocked
            UnlockableController.IsFeatureUnlocked = function(self, featureId, passId)
                if featureId == "EggHuntRadar" or featureId == "Easter2026Pass" or featureId == "VIP" then
                    return true
                end
                return oldFeature(self, featureId, passId)
            end
        end
        
        if GamepassController and type(GamepassController.IsOwned) == "function" then
            GamepassController.IsOwned = function(passId) return true end
        end

        if EggController then
            if type(EggController.IsRadarUnlocked) == "function" then
                EggController.IsRadarUnlocked = function() return true end
            end
            EggController.RadarUnlocked = true
            EggController.RadarEnabled = true
            EggController.RadarVideoUnlockExpireTimeStamp = workspace:GetServerTimeNow() + 9999999 

            if type(EggController.ChangeRadarEnabled) == "function" then
                EggController.ChangeRadarEnabled(true)
            elseif type(EggController.UnlockRadar) == "function" then
                EggController.UnlockRadar()
            end
        end
    end)
end

-- GELİŞMİŞ ESP & RADAR SİSTEMİ
local function ToggleESP()
    for _, v in pairs(workspace:GetDescendants()) do
        if (v.Name == "EggHuntCollectable" or v:HasTag("EggHuntCollectable")) and v:IsA("BasePart") then
            if Config.ESP then
                if not v:FindFirstChild("GodHighlight") then
                    local hl = Instance.new("Highlight", v)
                    hl.Name = "GodHighlight"
                    hl.FillColor = Color3.fromRGB(0, 255, 255)
                    hl.OutlineColor = Color3.new(1, 1, 1)
                    hl.FillTransparency = 0.5
                end
                if not v:FindFirstChild("GodLabel") then
                    local bb = Instance.new("BillboardGui", v)
                    bb.Name = "GodLabel"
                    bb.AlwaysOnTop = true
                    bb.Size = UDim2.new(0, 100, 0, 40)
                    bb.ExtentsOffset = Vector3.new(0, 3, 0)
                    
                    local txt = Instance.new("TextLabel", bb)
                    txt.Size = UDim2.new(1, 0, 1, 0)
                    txt.BackgroundTransparency = 1
                    txt.TextColor3 = Color3.fromRGB(0, 255, 127)
                    txt.TextStrokeTransparency = 0
                    txt.Font = Enum.Font.GothamBold
                    txt.TextSize = 12
                    
                    task.spawn(function()
                        while v and v.Parent and Config.ESP do
                            local char = LP.Character
                            if char and char:FindFirstChild("HumanoidRootPart") then
                                local dist = math.floor((char.HumanoidRootPart.Position - v.Position).Magnitude)
                                txt.Text = "YUMURTA\n[" .. dist .. "m]"
                            end
                            task.wait(0.1)
                        end
                        bb:Destroy()
                    end)
                end
            else
                if v:FindFirstChild("GodHighlight") then v.GodHighlight:Destroy() end
                if v:FindFirstChild("GodLabel") then v.GodLabel:Destroy() end
            end
        end
    end
end

-- INSTANT TELEPORT FARM DÖNGÜSÜ
task.spawn(function()
    while task.wait(0.2) do
        if Config.Farm then
            local eggs = {}
            for _, v in pairs(workspace:GetDescendants()) do
                if (v.Name == "EggHuntCollectable" or v:HasTag("EggHuntCollectable")) and v:IsA("BasePart") then
                    if not v:GetAttribute("Collected") and v.Transparency < 1 then
                        table.insert(eggs, v)
                    end
                end
            end

            for _, egg in ipairs(eggs) do
                if not Config.Farm then break end
                local char = LP.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    -- Direk Teleport (Tween kaldırıldı)
                    hrp.CFrame = egg.CFrame * CFrame.new(0, 2, 0)
                    
                    -- Bug fix: Server'ın teleportu ve yumurtayı algılaması için milisaniyelik gecikme
                    task.wait(0.15) 
                    
                    pcall(function() Remotes.invokeServer("EggCollected", egg.Name) end)
                end
            end
        end
    end
end)

-- UI TASARIMI
local ScreenGui = Instance.new("ScreenGui", LP:WaitForChild("PlayerGui"))
ScreenGui.Name = "Brookhaven_God_2026"
ScreenGui.ResetOnSpawn = false

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0, 260, 0, 440)
Main.Position = UDim2.new(0.5, -130, 0.5, -220)
Main.BackgroundColor3 = Color3.fromRGB(10, 10, 12)
Main.BorderSizePixel = 0
Main.Active = true
Main.Draggable = true

local UICorner = Instance.new("UICorner", Main)
UICorner.CornerRadius = UDim.new(0, 12)

local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 50)
Title.Text = "EASTER 2026 GOD MODE"
Title.TextColor3 = Color3.fromRGB(0, 255, 200)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 16
Title.BackgroundTransparency = 1

local function MakeButton(text, pos, var, callback)
    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0, 230, 0, 38)
    btn.Position = pos
    btn.Text = text .. (var and ": KAPALI" or "")
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.AutoButtonColor = true
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(function()
        if var then
            Config[var] = not Config[var]
            btn.Text = text .. (Config[var] and ": AKTİF" or ": KAPALI")
            btn.BackgroundColor3 = Config[var] and Color3.fromRGB(0, 180, 100) or Color3.fromRGB(25, 25, 30)
        end
        if callback then callback(btn) end
    end)
    return btn
end

-- Menü Öğeleri
MakeButton("INSTANT OTO FARM", UDim2.new(0, 15, 0, 60), "Farm")

-- Zorluk Seçici Buton
MakeButton("ZORLUK: " .. Config.Difficulty, UDim2.new(0, 15, 0, 105), nil, function(btn)
    DiffIndex = DiffIndex + 1
    if DiffIndex > #Difficulties then DiffIndex = 1 end
    
    Config.Difficulty = Difficulties[DiffIndex]
    btn.Text = "ZORLUK: " .. Config.Difficulty
    
    -- Server'a anında yeni zorluğu iletiyoruz
    pcall(function() Remotes.fireServer("ChangeDifficulty", Config.Difficulty) end)
end)

MakeButton("RADAR & ESP", UDim2.new(0, 15, 0, 150), "ESP", ToggleESP)

MakeButton("HIZLI KOŞU (60)", UDim2.new(0, 15, 0, 195), "SpeedActive", function()
    task.spawn(function()
        while Config.SpeedActive do
            if LP.Character and LP.Character:FindFirstChild("Humanoid") then
                LP.Character.Humanoid.WalkSpeed = 60
            end
            task.wait(0.1)
        end
        if LP.Character and LP.Character:FindFirstChild("Humanoid") then LP.Character.Humanoid.WalkSpeed = 16 end
    end)
end)

-- VIP Unlock Butonu
local VipBtn = Instance.new("TextButton", Main)
VipBtn.Size = UDim2.new(0, 230, 0, 45)
VipBtn.Position = UDim2.new(0, 15, 0, 290)
VipBtn.Text = "VIP & TÜMÜNÜ AÇ (BYPASS)"
VipBtn.BackgroundColor3 = Color3.fromRGB(140, 0, 255)
VipBtn.TextColor3 = Color3.new(1, 1, 1)
VipBtn.Font = Enum.Font.GothamBold
VipBtn.TextSize = 12
Instance.new("UICorner", VipBtn)

VipBtn.MouseButton1Click:Connect(function()
    GlobalBypass()
    VipBtn.Text = "SİSTEM BYPASS EDİLDİ!"
    VipBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
end)

-- Kapatma (X)
local Close = Instance.new("TextButton", Main)
Close.Size = UDim2.new(0, 30, 0, 30)
Close.Position = UDim2.new(1, -35, 0, 5)
Close.Text = "X"
Close.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
Close.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", Close).CornerRadius = UDim.new(1, 0)

Close.MouseButton1Click:Connect(function()
    _G.EasterGodModeExecuted = false
    Config.Farm = false
    Config.ESP = false
    ToggleESP()
    ScreenGui:Destroy()
end)

-- Sürükleme Desteği
local dragging, dragInput, dragStart, startPos
Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

print("[SUCCESS]: Brookhaven Easter 2026 God Mode V3.1 Yüklendi. İyi Oyunlar!")
